# Plantilla de variables de entorno para producción (Azure Container Apps)
# Copia este archivo a .env en el servidor y rellena los valores reales.
# NUNCA subas este archivo con valores reales al repositorio.

# Base de datos
DB_HOST=CHANGE_ME_DB_HOST
DB_USER=CHANGE_ME_DB_USER
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_NAME=CHANGE_ME_DB_NAME

# JWT — genera con: openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=CHANGE_ME_REPLACE_WITH_STRONG_SECRET_64_BYTES_BASE64

# CORS — FQDNs del frontend en Azure (separados por coma, sin espacios)
CORS_ORIGINS=https://CHANGE_ME-frontend.azurecontainerapps.io

# Node
NODE_ENV=production
